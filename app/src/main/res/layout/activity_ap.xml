<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fitsSystemWindows="true"
	tools:context=".ui.activity.DeviceInfoActivity">
	
	<androidx.appcompat.widget.LinearLayoutCompat
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:orientation="vertical"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintTop_toBottomOf="@+id/app_bar">
		
		<TextView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/ap_instruction"
			android:textColor="@color/text_secondary"
			android:layout_marginLeft="@dimen/dimen_25dp"
			android:layout_marginRight="@dimen/dimen_25dp"
			android:layout_marginTop="15dp"
			android:textSize="16sp" />
	
		<androidx.appcompat.widget.AppCompatImageView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:src="@mipmap/ic_ap"
			android:layout_marginTop="@dimen/dimen_10dp"/>
		
		<RelativeLayout
			android:layout_width="match_parent"
			android:layout_height="0dp"
			android:layout_weight="1"
			android:padding="@dimen/dimen_30dp">
			
			<androidx.appcompat.widget.AppCompatButton
				android:id="@+id/btnAp"
				android:layout_above="@+id/btnNext"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/button_ap_selector"
				android:text="@string/go_wifi_setting"
				android:textAllCaps="false"
				android:layout_marginBottom="@dimen/dimen_15dp"
				android:textColor="?attr/app_normal_color" />
			
			<androidx.appcompat.widget.AppCompatButton
				android:id="@+id/btnNext"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/button_next_selector"
				android:text="@string/next_step"
				android:layout_alignParentBottom="true"
				android:textAllCaps="false"
				android:textColor="@drawable/txt_wifi_config_color" />
			
		</RelativeLayout>

	</androidx.appcompat.widget.LinearLayoutCompat>
	
	<include
		android:id="@+id/app_bar"
		layout="@layout/app_bar_printer_list" />

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <include android:id="@+id/commonAppBar" layout="@layout/common_app_bar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTaskInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPageList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/main_continue_print"
            android:textSize="14sp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnReprintSelected"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/task_detail_btn_reprint_selected"
            android:textSize="14sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnReprintAll"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/task_detail_reprint_all_btn"
            android:textSize="14sp"
            android:layout_marginStart="4dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnViewProgress"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/task_detail_btn_view_progress"
            android:textSize="14sp"
            android:backgroundTint="@color/btn_primary"
            android:textColor="@color/btn_primary_text"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
